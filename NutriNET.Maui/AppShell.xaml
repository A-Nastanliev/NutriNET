<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NutriNET.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NutriNET.Maui"
    xmlns:authentication="clr-namespace:NutriNET.Maui.Views.Authentication"
    xmlns:settings="clr-namespace:NutriNET.Maui.Views.Settings"
    xmlns:foods="clr-namespace:NutriNET.Maui.Views.Food"
    xmlns:recipes="clr-namespace:NutriNET.Maui.Views.Recipes"
    xmlns:meals="clr-namespace:NutriNET.Maui.Views.Meals"
    Title="NutriNET.Maui"
    xmlns:role="clr-namespace:NutriNET.Maui.Authentication"
    Shell.FlyoutBehavior="Disabled">


    <ShellContent
      Shell.NavBarIsVisible="False"
      Shell.TabBarIsVisible="False"
      FlyoutItemIsVisible="False"
      ContentTemplate="{DataTemplate authentication:LoadingPage}"
      Route="LoadingPage">
    </ShellContent>

    <ShellContent
      Shell.NavBarIsVisible="False"
      Shell.TabBarIsVisible="False"
      FlyoutItemIsVisible="False"
      ContentTemplate="{DataTemplate authentication:LoginPage}"
      Route="LoginPage">
    </ShellContent>

    <ShellContent
      Shell.NavBarIsVisible="False"
      Shell.TabBarIsVisible="False"
      FlyoutItemIsVisible="False"
      ContentTemplate="{DataTemplate authentication:SignUpPage}"
      Route="SignUpPage">
    </ShellContent>

    <TabBar>
        <Tab Title="{local:Translate MealsTabTitle}" Icon="home_icon.png">
            <ShellContent Title="{local:Translate TodayTabPageTitle}"
                 ContentTemplate="{DataTemplate meals:TodayPage}"
                 Route="TodayPage"/>
            <ShellContent Title="{local:Translate HistoryTabPageTitle}"
               ContentTemplate="{DataTemplate meals:HistoryPage}"
               Route="HistoryPage"/>
        </Tab>
        <Tab Title="{local:Translate FoodsTabTitle}" Icon="food_icon.png">
            <ShellContent Title="{local:Translate FoodCatalogTabPageTitle}"
             ContentTemplate="{DataTemplate foods:FoodCatalogPage}"
             Route="FoodCatalogPage"/>
            <ShellContent Title="{local:Translate MyRequestsTabPageTitle}"
               ContentTemplate="{DataTemplate foods:MyFoodRequestsPage}"
               IsVisible="{Binding Role, Source={StaticResource User}, Converter={StaticResource EqualsConverter},  ConverterParameter={x:Static role:UserRole.User}}"
               Route="MyFoodRequestsPage"/>
            <ShellContent Title="{local:Translate FoodRequestsTabPageTitle}"
              ContentTemplate="{DataTemplate foods:FoodRequestsPage}"
              IsVisible="{Binding Role, Source={StaticResource User}, Converter={StaticResource NotEqualsConverter},  ConverterParameter={x:Static role:UserRole.User}}"
              Route="FoodRequestsPage"/>
        </Tab>
        <Tab Title="{local:Translate RecipesTabTitle}" Icon="recipes_icon.png">
            <ShellContent Title="{local:Translate RecipeCatalogTabPageTitle}"
               ContentTemplate="{DataTemplate recipes:RecipeCatalogPage}"
               Route="RecipeCatalogPage"/>
            <ShellContent Title="{local:Translate FollowingRecipesTabPageTitle}"
                ContentTemplate="{DataTemplate recipes:FollowingRecipesPage}"
                Route="FollowingRecipesPage"/>
            <ShellContent Title="{local:Translate MyRecipesTabPageTitle}"
                ContentTemplate="{DataTemplate recipes:MyRecipesPage}"
                Route="MyRecipesPage"/>
        </Tab>
        <Tab Title="{local:Translate SettingsTitle}" Icon="settings_icon.png">
            <ShellContent Title="{local:Translate SettingsTitle}"
             ContentTemplate="{DataTemplate settings:SettingsPage}"
             Route="SettingsPage"/>
        </Tab>
        <Tab Title="{local:Translate ManagementTabTitle}" Icon="management_icon.png"
            IsVisible="{Binding Role, Source={StaticResource User}, Converter={StaticResource RoleVisibilityConverter}, ConverterParameter='Administrator,Moderator'}">
            <ShellContent
                Title="{local:Translate RestrictionsTabPageTitle}"
                ContentTemplate="{DataTemplate settings:CommentRestrictionsPage}"
                Route="CommentRestrictionsPage"/>

            <ShellContent
                Title="{local:Translate ModRequestsTabPageTitle}"
                IsVisible="{Binding Role, Source={StaticResource User}, Converter={StaticResource EqualsConverter},  ConverterParameter={x:Static role:UserRole.Administrator}}"
                ContentTemplate="{DataTemplate settings:ModeratorRequestsPage}"
                Route="ModeratorRequestsPage"/>

            <ShellContent
                IsVisible="{Binding Role, Source={StaticResource User}, Converter={StaticResource EqualsConverter},  ConverterParameter={x:Static role:UserRole.Administrator}}"
                Title="{local:Translate ModeratorsTabPageTitle}"
                ContentTemplate="{DataTemplate settings:ManageModeratorsPage}"
                Route="ManageModeratorsPage"/>
        </Tab>
    </TabBar>

</Shell>
