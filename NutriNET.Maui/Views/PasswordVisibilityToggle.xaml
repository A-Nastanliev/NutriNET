<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="NutriNET.Maui.Views.PasswordVisibilityToggle">

    <Grid HeightRequest="48" WidthRequest="48">
        <Button
            x:Name="ButtonBase"
            BackgroundColor="Transparent"
            Clicked="OnClicked" />

        <Image
            x:Name="Icon" Source="eye_icon.png"
            Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="36" WidthRequest="36">
            <Image.Behaviors>
                <toolkit:IconTintColorBehavior TintColor="White" />
            </Image.Behaviors>
        </Image>
    </Grid>
</ContentView>
