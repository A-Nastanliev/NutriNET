<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NutriNET.Maui.Views.Recipes.RecipeListPage"
             xmlns:vm="clr-namespace:NutriNET.Maui.ViewModels.Recipes"
             x:DataType="vm:RecipeListLoaderVM"
             xmlns:local="clr-namespace:NutriNET.Maui"
             xmlns:foodViews="clr-namespace:NutriNET.Maui.Views.Food"
             xmlns:buttons="clr-namespace:Syncfusion.Maui.Toolkit.Buttons;assembly=Syncfusion.Maui.Toolkit"
             Title="{Binding RecipeList.Name}">

    <Grid RowDefinitions="Auto,*">
        <CollectionView ItemsSource="{Binding Recipes}"  VerticalOptions="Fill" Grid.Row="1" Margin="6"
          RemainingItemsThreshold="3" VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never"
          RemainingItemsThresholdReachedCommand="{Binding LoadCommand}">
            <CollectionView.EmptyView>
                <Label  Text="{local:Translate RecipeListEmpty}" HorizontalOptions="Center" VerticalOptions="Center"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <foodViews:FoodView
                        TapCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectFoodCommand}"
                        HoldCommand="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveFromListCommand}"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>