<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NutriNET.Maui.Views.Authentication.ForgotPasswordPage"
             xmlns:local="clr-namespace:NutriNET.Maui"
             Title="{local:Translate ForgotPasswordPageTitle}"
             Shell.TabBarIsVisible="False"
             xmlns:vm="clr-namespace:NutriNET.Maui.ViewModels.Authentication"
             x:DataType="vm:ForgotPasswordVM">
    
    <Grid HorizontalOptions="Center" VerticalOptions="Start" RowDefinitions="Auto, Auto, Auto" RowSpacing="20" Padding="24,40,24,0">

        <Label FontSize="Small" Text="{local:Translate ForgotPasswordSubtitle}" Grid.Row="0"/>
        <VerticalStackLayout Grid.Row="1" Spacing="4">
            <Label Text="{local:Translate Email}" FontSize="Small"/>
            <Entry
                 Placeholder="you@example.com" Keyboard="Email"  Text="{Binding EmailAddress}" TextColor="White"
                 PlaceholderColor="{StaticResource Gray400}" BackgroundColor="#1E1E1E" FontSize="Small" />
        </VerticalStackLayout>

        <Button
             Text="{local:Translate SendCode}" Grid.Row="2"  Command="{Binding SendCodeCommand}"  BackgroundColor="{StaticResource Primary}"
             FontAttributes="Bold" FontSize="Small" CornerRadius="20" />
    </Grid>
</ContentPage>