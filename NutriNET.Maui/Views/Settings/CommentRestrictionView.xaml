<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NutriNET.Maui.Views.Settings.CommentRestrictionView"
             xmlns:vm="clr-namespace:NutriNET.Maui.Models.User"
             xmlns:local="clr-namespace:NutriNET.Maui"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:DataType="vm:CommentRestrictionVM"
             x:Name="Root">

    <ContentView.IsVisible>
        <Binding Path="Id"
             Converter="{StaticResource NotEqualsConverter}">
            <Binding.ConverterParameter>
                <x:Int32>0</x:Int32>
            </Binding.ConverterParameter>
        </Binding>
    </ContentView.IsVisible>

    <Border
        Style="{StaticResource SectionCard}">
        <Border.GestureRecognizers>
            <TapGestureRecognizer
               Command="{Binding TapCommand, Source={x:Reference Root}}"
               CommandParameter="{Binding BindingContext, Source={x:Reference Root}}"/>
        </Border.GestureRecognizers>
        <VerticalStackLayout Spacing="8" Background="Transparent" >

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Start">
                <Border
                  WidthRequest="50"
                  HeightRequest="50"
                  StrokeThickness="1"
                  Stroke="LightGray"
                  StrokeShape="RoundRectangle 50"
                  VerticalOptions="Center">

                    <Image Source="{Binding PublicUser.ProfilePictureSource}"
                         Aspect="AspectFill">
                        <Image.Clip>
                            <EllipseGeometry
                              Center="25,25"
                              RadiusX="25"
                              RadiusY="25" />
                        </Image.Clip>
                    </Image>
                </Border>

                <Label
                  Text="{Binding PublicUser.Username}"
                  FontAttributes="Bold"
                  FontSize="Medium"
                  VerticalOptions="Center" />
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer
                       Command="{Binding NameTapCommand, Source={x:Reference Root}}"
                       CommandParameter="{Binding BindingContext.PublicUser, Source={x:Reference Root}}"/>
                </HorizontalStackLayout.GestureRecognizers>
            </HorizontalStackLayout>

            <Label
              Text="{Binding Reason}"
              FontSize="Medium" HorizontalTextAlignment="Justify" 
              LineBreakMode="WordWrap" IsVisible="{Binding Reason, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Null}}" />
            <HorizontalStackLayout Spacing="8">
                <VerticalStackLayout Spacing="8">
                    <Label
                      FontSize="Small" TextColor="White" VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{local:Translate Start}" />
                                <Span Text=":" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <Label
                       FontSize="Small" TextColor="White" VerticalOptions="Center" >
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{local:Translate End}" />
                                <Span Text=":" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="{Binding StartDate, Converter={StaticResource TimeConverter}}" FontSize="Small"
                        TextColor="White" VerticalOptions="Center" HorizontalOptions="Start" />
                    <Label
                        Text="{Binding EndDate, Converter={StaticResource TimeConverter}}" 
                        IsVisible="{Binding EndDate, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Null}}"
                        FontSize="Small" VerticalOptions="Center" TextColor="White" HorizontalOptions="Start" />
                    <Label
                        Text="{local:Translate NoEndDate}" 
                        IsVisible="{Binding EndDate, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Null}}"
                        FontSize="Small" VerticalOptions="Center" TextColor="White" HorizontalOptions="Start" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
