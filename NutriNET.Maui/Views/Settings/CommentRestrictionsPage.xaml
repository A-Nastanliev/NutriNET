<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NutriNET.Maui.Views.Settings.CommentRestrictionsPage"
             xmlns:segmentedControl="clr-namespace:Syncfusion.Maui.Toolkit.SegmentedControl;assembly=Syncfusion.Maui.Toolkit"
             xmlns:vm="clr-namespace:NutriNET.Maui.ViewModels.Settings"
             xmlns:views="clr-namespace:NutriNET.Maui.Views.Settings"
             x:DataType="vm:CommentRestrictionsVM"
             xmlns:local="clr-namespace:NutriNET.Maui"
             Title="{local:Translate CommentRestrictionsPageTitle}">

    <AbsoluteLayout>
        <Grid Padding="16" RowSpacing="8" RowDefinitions="Auto, *"
              AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All" >
            <Label Text="{Binding SelectedRestrictionStatus.Key}" TextColor="{DynamicResource SecondaryDarkText}" VerticalOptions="Center" HorizontalOptions="Fill"
                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="Medium">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectRestrictionStatusCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <RefreshView IsRefreshing="{Binding IsRefreshing}"
                Command="{Binding RefreshCommand}"  Grid.Row="1">
                <CollectionView VerticalOptions="Fill"
                    ItemsSource="{Binding CommentRestrictions}"
                    RemainingItemsThreshold="3" VerticalScrollBarVisibility="Never"
                    RemainingItemsThresholdReachedCommand="{Binding LoadCommand}">

                    <CollectionView.EmptyView>
                        <Label  Text="{local:Translate CommentRestrictionsEmpty}"
                     HorizontalOptions="Center"
                     VerticalOptions="Center"/>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <views:CommentRestrictionView 
                            x:DataType="views:CommentRestrictionView" Margin="6, 10"    
                            NameTapCommand="{Binding Source={RelativeSource FindAncestor, AncestorType={x:Type ContentPage}},
                                Path=BindingContext.VisitProfileCommand}"
                            TapCommand="{Binding Source={RelativeSource FindAncestor, AncestorType={x:Type ContentPage}},
                                Path=BindingContext.SelectCommentRestrictionCommand}"/>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </RefreshView>
        </Grid>
        <Grid
            x:Name="Overlay" IsVisible="False" BackgroundColor="#771A1A1A" RowDefinitions="*, Auto"
            AbsoluteLayout.LayoutBounds="0,0,1,1" AbsoluteLayout.LayoutFlags="All">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOverlayTapped"/>
                </BoxView.GestureRecognizers>
            </BoxView>
            <BoxView  BackgroundColor="#80000000" Grid.RowSpan="2"/>
            <Grid  x:Name="BottomSheetContent" RowDefinitions="Auto" Grid.Row="1" HorizontalOptions="Fill" 
                VerticalOptions="End" MaximumHeightRequest="500">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                </Grid.GestureRecognizers>
                <Border Style="{StaticResource SectionCard}" StrokeShape="RoundRectangle 20,20,0,0" Padding="20,20,20,10">
                    <ScrollView HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never">
                        <VerticalStackLayout Spacing="8" Background="Transparent" >
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Start">
                                <Border WidthRequest="50"  HeightRequest="50" StrokeThickness="1" Stroke="LightGray" StrokeShape="RoundRectangle 50"
                                        VerticalOptions="Center">
                                    <Image Source="{Binding SelectedCommentRestriction.PublicUser.ProfilePictureSource}" Aspect="AspectFill">
                                        <Image.Clip>
                                            <EllipseGeometry Center="25,25" RadiusX="25" RadiusY="25" />
                                        </Image.Clip>
                                    </Image>
                                </Border>
                                <Label Text="{Binding SelectedCommentRestriction.PublicUser.Username}" FontAttributes="Bold" FontSize="Medium" VerticalOptions="Center" />
                                <HorizontalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource FindAncestor, AncestorType={x:Type ContentPage}}, 
                                             Path=BindingContext.VisitProfileCommand}"
                                        CommandParameter="{Binding BindingContext.SelectedCommentRestriction.PublicUser, 
                                        Source={RelativeSource FindAncestor, AncestorType={x:Type ContentPage}}}"/>
                                </HorizontalStackLayout.GestureRecognizers>
                            </HorizontalStackLayout>
                            <Label Text="{Binding SelectedCommentRestriction.Reason}" FontSize="Medium" LineBreakMode="WordWrap"
                               IsVisible="{Binding SelectedCommentRestriction.Reason, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Null}}"/>
                            <HorizontalStackLayout Spacing="8">
                                <VerticalStackLayout Spacing="8">
                                    <Label FontSize="Small" TextColor="White" VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{local:Translate Start}" />
                                                <Span Text=":" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label FontSize="Small" TextColor="White" VerticalOptions="Center" >
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{local:Translate End}" />
                                                <Span Text=":" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="{Binding SelectedCommentRestriction.StartDate, Converter={StaticResource TimeConverter}}" FontSize="Small"
                                        TextColor="White" VerticalOptions="Center" HorizontalOptions="Start" />
                                    <Label
                                        Text="{Binding SelectedCommentRestriction.EndDate, Converter={StaticResource TimeConverter}}" 
                                        IsVisible="{Binding SelectedCommentRestriction.EndDate, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Null}}"
                                        FontSize="Small" VerticalOptions="Center" TextColor="White" HorizontalOptions="Start" />
                                    <Label
                                        Text="{local:Translate NoEndDate}" 
                                        IsVisible="{Binding SelectedCommentRestriction.EndDate, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Null}}"
                                        FontSize="Small" VerticalOptions="Center" TextColor="White" HorizontalOptions="Start" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <Button Text="{local:Translate EndButton}" CornerRadius="20" Command="{Binding EndCommentRestrictionCommand}" HorizontalOptions="Center" IsVisible="{Binding CanEndRestriction}"/>
                        </VerticalStackLayout>
                    </ScrollView>
                </Border>
            </Grid>
        </Grid>
    </AbsoluteLayout>
</ContentPage>