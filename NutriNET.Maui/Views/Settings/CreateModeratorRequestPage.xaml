<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NutriNET.Maui.Views.Settings.CreateModeratorRequestPage"
             xmlns:local="clr-namespace:NutriNET.Maui"
             Title="{local:Translate CreateModeratorRequestPageTitle}"
             xmlns:vm="clr-namespace:NutriNET.Maui.ViewModels.Settings"
             x:DataType="vm:CreateModeratorRequestVM">

    <Grid RowDefinitions="*,Auto"
      Padding="24">

        <ScrollView Grid.Row="0">
            <Editor Text="{Binding Description, Mode=TwoWay}"
                    MaxLength="500"
                    AutoSize="TextChanges" Background="Transparent"
                    Placeholder="{local:Translate ModeratorRequestDescriptionPlaceholder}"
                    TextColor="White" />
        </ScrollView>

        <Button Grid.Row="1"
            Text="{local:Translate SubmitRequest}"
            Command="{Binding SubmitRequestCommand}"
            BackgroundColor="{DynamicResource Primary}"
            TextColor="White" CornerRadius="20"
            HorizontalOptions="Fill"
            Margin="0,16,0,0" />
    </Grid>
</ContentPage>