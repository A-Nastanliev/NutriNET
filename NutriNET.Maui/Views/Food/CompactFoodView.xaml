<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NutriNET.Maui.Views.Food.CompactFoodView"         
             xmlns:vm="clr-namespace:NutriNET.Maui.Models.Food"
             x:DataType="vm:FoodVM"
             xmlns:foodType="clr-namespace:NutriNET.Maui.Models.Food"
             xmlns:local="clr-namespace:NutriNET.Maui"
             x:Name="Root">
    <Border
    Margin="6" StrokeShape="RoundRectangle 10"
    Padding="0,1" HorizontalOptions="Fill" >
        <Border.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding TapCommand, Source={x:Reference Root}}"
                CommandParameter="{Binding BindingContext, Source={x:Reference Root}}"/>
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="*,4*">
            <Image
              Aspect="AspectFill" HeightRequest="62" Grid.Column="0"
              Source="{Binding ImageSource}" />
            <Grid x:Name="InnerGrid" Grid.Column="1" RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="1.3*,*,*,*">
                <Label
                 Text="{Binding Name}" FontSize="Small" Padding="8,0"
                 LineBreakMode="TailTruncation" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" HorizontalTextAlignment="Start" VerticalTextAlignment="Center"/>
                <Label Text="{Binding ExtraInfo}" LineBreakMode="TailTruncation" FontSize="Micro"  Grid.Row="1" Grid.ColumnSpan="3" 
                   Grid.Column="0" HorizontalTextAlignment="Start" VerticalTextAlignment="Center" Padding="8,0">
                    <Label.IsVisible>
                        <MultiBinding Converter="{StaticResource AllTrueMultiConverter}">
                            <Binding Path="FoodType" Converter="{StaticResource EqualsConverter}" 
                             ConverterParameter="{x:Static foodType:FoodType.Food}" />
                            <Binding Path="ExtraInfo" Converter="{StaticResource NotEqualsConverter}"
                            ConverterParameter="{x:Null}" />
                        </MultiBinding>
                    </Label.IsVisible>
                </Label>
                <Label Text="{local:Translate NoBrandText}" LineBreakMode="TailTruncation" FontSize="Micro" Grid.Row="1" Grid.ColumnSpan="3" 
                   Grid.Column="0" HorizontalTextAlignment="Start" VerticalTextAlignment="Center" Padding="8,0">
                    <Label.IsVisible>
                        <MultiBinding Converter="{StaticResource AllTrueMultiConverter}">
                            <Binding Path="FoodType" Converter="{StaticResource EqualsConverter}" 
                            ConverterParameter="{x:Static foodType:FoodType.Food}" />
                            <Binding Path="ExtraInfo"  Converter="{StaticResource EqualsConverter}"  ConverterParameter="{x:Null}" />
                        </MultiBinding>
                    </Label.IsVisible>
                </Label>
                <HorizontalStackLayout Spacing="4" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Padding="8,0">
                    <HorizontalStackLayout.IsVisible>
                        <Binding Path="FoodType" Converter="{StaticResource EqualsConverter}" ConverterParameter="{x:Static foodType:FoodType.RecipeFood}" />
                    </HorizontalStackLayout.IsVisible>
                    <Label Text="{local:Translate By}" FontSize="Micro" />
                    <Label Text="{Binding ExtraInfo}" FontSize="Micro" LineBreakMode="TailTruncation">
                        <Label.IsVisible>
                            <Binding Path="ExtraInfo" Converter="{StaticResource NotEqualsConverter}" ConverterParameter="{x:Null}" />
                        </Label.IsVisible>
                    </Label>
                    <Label Text="{local:Translate UnknownUser}" FontSize="Micro" LineBreakMode="TailTruncation">
                        <Label.IsVisible>
                            <Binding Path="ExtraInfo" Converter="{StaticResource EqualsConverter}" ConverterParameter="{x:Null}" />
                        </Label.IsVisible>
                    </Label>
                </HorizontalStackLayout>
                <Label FontSize="Small" Grid.Row="2" LineBreakMode="TailTruncation"
                 HorizontalOptions="Center" Grid.Column="0" VerticalOptions="Center" VerticalTextAlignment="Center" HorizontalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding Calories}" />
                            <Span Text=" " />
                            <Span Text="{local:Translate kcal}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="Small" TextColor="{DynamicResource ProteinColor}" Grid.Row="2" 
                    Grid.Column="1" HorizontalOptions="Center" VerticalTextAlignment="Center" VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding Proteins}" />
                            <Span Text=" " />
                            <Span Text="{local:Translate grams}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="Small" TextColor="{DynamicResource CarbsColor}" VerticalTextAlignment="Center" VerticalOptions="Center"
                Grid.Row="2" Grid.Column="2" HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding Carbohydrates}" />
                            <Span Text=" " />
                            <Span Text="{local:Translate grams}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label FontSize="Small" TextColor="{DynamicResource FatColor}" Grid.Row="2" 
                Grid.Column="3" HorizontalOptions="Center"  VerticalTextAlignment="Center" VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding Fats}" />
                            <Span Text=" " />
                            <Span Text="{local:Translate grams}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
        </Grid>
    </Border>
</ContentView>
